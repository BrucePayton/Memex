# Memex Deployment Environment Variables Template

# Memex version tag
MEMEX_VERSION=0.1.0

# Nginx external port (mapped to container 3011)
MEMEX_PORT=3011

# Data persistence directories
MEMEX_DATA_DIR=./data
MEMEX_PROJECTS_DIR=./projects
MEMEX_GIT_DIR=.git

# Auto git commit configuration
MEMEX_GIT_AUTO_COMMIT=true

# Active project slug (empty = use projects.json active)
MEMEX_ACTIVE_PROJECT=askdata-platform

# Timezone
MEMEX_TZ=Asia/Shanghai

# SSL certificate directory
MEMEX_SSL_DIR=./ssl

# Static files directory
MEMEX_STATIC_DIR=./static

# MCP Server transport mode
# "stdio" (default, for local Claude Code) or "http" (for remote deployment)
MEMEX_MCP_TRANSPORT=stdio

# ─── CLI Settings ───

# MEMEX_CLI_TYPE=claude
# MEMEX_CLI_BINARY=claude

# ─── Port Configuration ───
# Dashboard internal port
MEMEX_DASHBOARD_PORT=8000
# Dashboard external port (direct access, bypassing nginx)
MEMEX_DASHBOARD_EXPOSED_PORT=8002
# MCP Server port
MEMEX_MCP_PORT=8081

# ─── Timeout Configuration ───
# Claude CLI timeout (seconds) — Ingest can take long
MEMEX_CLAUDE_TIMEOUT=600
# Quick diagnostic timeout (seconds)
MEMEX_CLAUDE_QUICK_TIMEOUT=30
# Stream heartbeat interval (seconds)
MEMEX_HEARTBEAT_INTERVAL=10
# Nginx proxy timeout (seconds)
MEMEX_PROXY_TIMEOUT=300

# ─── Health Check Configuration ───
# Health check interval (seconds)
MEMEX_HEALTHCHECK_INTERVAL=30
# Health check timeout (seconds)
MEMEX_HEALTHCHECK_TIMEOUT=10
# MCP healthcheck timeout (shorter)
MEMEX_MCP_HEALTHCHECK_TIMEOUT=5

# ─── Logging Configuration ───
# Docker log max size
MEMEX_LOG_MAX_SIZE=10m
# Docker log max files
MEMEX_LOG_MAX_FILE=3

# ─── Nginx Configuration ───
# Nginx worker connections
MEMEX_NGINX_WORKER_CONNECTIONS=1024
# Nginx client max body size
MEMEX_CLIENT_MAX_BODY_SIZE=100m
# Nginx keepalive timeout
MEMEX_KEEPALIVE_TIMEOUT=65
